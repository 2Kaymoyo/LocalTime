<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.localtime.desktop</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>FIREBASE_PROJECT_ID</key>
        <string>YOUR_PROJECT_ID</string>
        <key>FIREBASE_API_KEY</key>
        <string>YOUR_FIREBASE_API_KEY</string>
    </dict>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/path/to/LocalTime/desktop_agent.py</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/path/to/LocalTime/agent_out.log</string>
    <key>StandardErrorPath</key>
    <string>/path/to/LocalTime/agent_err.log</string>
</dict>
</plist>
