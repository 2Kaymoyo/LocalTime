{
  "manifest_version": 3,
  "name": "LocalTime Tracker (Cloud)",
  "version": "2.0",
  "description": "Silently logs active tab directly to Firebase Firestore.",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://firestore.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}